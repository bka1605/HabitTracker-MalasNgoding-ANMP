<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.anmp.habittracker_malasngoding_anmp.view.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/actionDashboardFragment"
            app:destination="@id/dashboardFragment" />
    </fragment>
    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.anmp.habittracker_malasngoding_anmp.view.DashboardFragment"
        android:label="Dashboard"
        tools:layout="@layout/fragment_dashboard">
        <action
            android:id="@+id/actionHabitFragment"
            app:destination="@id/habitFragment" />
    </fragment>
    <fragment
        android:id="@+id/habitFragment"
        android:name="com.anmp.habittracker_malasngoding_anmp.view.HabitFragment"
        android:label="CreateHabit"
        tools:layout="@layout/fragment_habit">
        <action
            android:id="@+id/actionBackDashboardFragment"
            app:destination="@id/dashboardFragment" />
    </fragment>
</navigation>